# DocView Environment Variables
# Copy this file to .env and adjust values

# Server
DOCVIEW_PORT=4000
DOCVIEW_HOST=localhost
DOCVIEW_AUTO_OPEN=true

# Rendering
DOCVIEW_THEME=auto
DOCVIEW_MERMAID_ENABLED=true
DOCVIEW_KATEX_ENABLED=true

# Security
DOCVIEW_MAX_FILE_SIZE_MB=10
DOCVIEW_ALLOW_SYMLINKS=false

# Logging
DOCVIEW_LOG_LEVEL=info
NODE_ENV=development
